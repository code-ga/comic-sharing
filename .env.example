# Database Configuration
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dashboard_password
POSTGRES_DB=k8s_dashboard
DATABASE_URL=postgresql://dashboard:dashboard_password@postgres:5432/k8s_dashboard

# Backend Configuration
NODE_ENV=production
PORT=3001
BETTER_AUTH_SECRET=your-secret-key-here

# Frontend Configuration (server-side only: not exposed to the browser)
BACKEND_TARGET_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# OAuth Provider Credentials
# Get these from your OAuth provider developer consoles
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
